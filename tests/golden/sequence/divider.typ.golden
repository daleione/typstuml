#set page(width: auto, height: auto, margin: 8pt)
#set text(size: 10pt)
#import "/blockcell/lib.typ": *

#align(center)[*Divider sections*]

#seq-puml(width: 360pt, "participant Client
participant Server

== Handshake ==
Client -> Server : SYN
Server --> Client : SYN-ACK
Client -> Server : ACK
== Steady state ==
Client -> Server : GET /
Server --> Client : 200 OK
== Teardown ==
Client -> Server : FIN
Server --> Client : FIN-ACK
")
