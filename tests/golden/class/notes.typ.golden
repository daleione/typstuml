    (x: 23.25pt, y: 174.00pt, kind: "note", body: [single-line hint]),
    (x: 15.00pt, y: 18.00pt, kind: "note", body: [multi-line note \ with two paragraphs]),
    (x: 169.50pt, y: 18.00pt, kind: "note", body: [free-floating note]),
  ),
  edges: (
    (from: 0, to: 1, head-from: "none", head-to: "none", style: "dashed", from-side: "bot", to-side: "top", path: ((c1: (153.12pt, 150.00pt), c2: (77.25pt, 150.00pt), end: (77.25pt, 162.00pt)), (c1: (77.25pt, 166.00pt), c2: (77.25pt, 170.00pt), end: (77.25pt, 174.00pt)))),
    (from: 2, to: 0, head-from: "none", head-to: "none", style: "dashed", from-side: "bot", to-side: "top", path: ((c1: (77.25pt, 60.00pt), c2: (153.12pt, 60.00pt), end: (153.12pt, 72.00pt)), (c1: (153.12pt, 76.00pt), c2: (153.12pt, 80.00pt), end: (153.12pt, 84.00pt)))),
    (from: 3, to: 0, head-from: "none", head-to: "none", style: "dashed", from-side: "bot", to-side: "top", label: [refers to], path: ((c1: (229.00pt, 54.00pt), c2: (153.12pt, 54.00pt), end: (153.12pt, 72.00pt)), (c1: (153.12pt, 76.00pt), c2: (153.12pt, 80.00pt), end: (153.12pt, 84.00pt)))),
