#set page(width: auto, height: auto, margin: 8pt)
#set text(size: 10pt)
#import "/blockcell/lib.typ": *

#state-layout(
  nodes: (
    (id: "Open", kind: "simple", x: 30.00pt, y: 94.00pt, w: 123.10pt, h: 60.00pt, display: "Open", body: ("entry / reserve stock", "exit / release hold"), fill: none, border-style: "solid", border-color: none),
    (id: "Paid", kind: "simple", x: 63.55pt, y: 200.00pt, w: 56.00pt, h: 32.00pt, display: "Paid", body: (), fill: none, border-style: "solid", border-color: none),
    (id: "Shipped", kind: "simple", x: 58.85pt, y: 278.00pt, w: 65.40pt, h: 32.00pt, display: "Shipped", body: (), fill: none, border-style: "solid", border-color: none),
    (id: "__initial__", kind: "initial", x: 82.55pt, y: 30.00pt, w: 18.00pt, h: 18.00pt, display: "", body: (), fill: none, border-style: "solid", border-color: none),
    (id: "__final__", kind: "final", x: 82.55pt, y: 356.00pt, w: 18.00pt, h: 18.00pt, display: "", body: (), fill: none, border-style: "solid", border-color: none),
  ),
  transitions: (
    (from: "__initial__", to: "Open", event: none, guard: none, action: none, style: "solid", color: none, self-loop: false, back: false, bow-side: "max"),
    (from: "Open", to: "Paid", event: "pay", guard: "funds ok", action: "capture()", style: "solid", color: none, self-loop: false, back: false, bow-side: "max"),
    (from: "Paid", to: "Shipped", event: "dispatch", guard: none, action: "notify()", style: "solid", color: none, self-loop: false, back: false, bow-side: "max"),
    (from: "Paid", to: "Open", event: "refund", guard: none, action: none, style: "solid", color: none, self-loop: false, back: true, bow-side: "max"),
    (from: "Shipped", to: "__final__", event: none, guard: none, action: none, style: "solid", color: none, self-loop: false, back: false, bow-side: "max"),
  ),
  notes: (
  ),
  page: (279.10pt, 404.00pt),
  title: "Order lifecycle",
  hide-empty-description: false,
  direction: "tb",
)
