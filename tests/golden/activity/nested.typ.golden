#set page(width: auto, height: auto, margin: 8pt)
#set text(size: 10pt)
#import "/blockcell/lib.typ": *

#align(center)[*Order processing*]

#align(center, flow-col(
  start-marker(),
  process[Receive order],
  branch-merge([Stock OK?],
    yes: flow-col(
      process[Decrement stock],
      fork-bar(
        case([], flow-col(
          process[Email confirmation],
        )),
        case([], flow-col(
          process[Notify warehouse],
        )),
      ),
      flow-loop(
        flow-col(
          process[Try payment],
          decision[failed?],
        ),
        back-label: [yes],
      ),
      process[Ship],
    ),
    no: flow-col(
      process[Reply out-of-stock],
      stop-marker(),
    ),
    yes-label: [yes],
    no-label: [no],
    no-detach: true,
  ),
  process[Update stats],
  stop-marker(),
))
