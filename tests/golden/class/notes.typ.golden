#set page(width: auto, height: auto, margin: 8pt)
#set text(size: 10pt)
#import "/blockcell/lib.typ": *

#class-layout(
  classes: (
    (x: 15.25pt, y: 48.00pt, kind: "class", name: [Foo], fields: ((vis: "+", body: [name: String]),), methods: ((vis: "+", body: [render(): void]),)),
    (x: 11.25pt, y: 114.00pt, kind: "note", body: [single-line hint]),
    (x: 3.00pt, y: 6.00pt, kind: "note", body: [multi-line note \ with two paragraphs]),
    (x: 133.50pt, y: 6.00pt, kind: "note", body: [free-floating note]),
  ),
  edges: (
    (from: 0, to: 1, head-from: "none", head-to: "none", style: "dashed", path: ((c1: (65.25pt, 106.00pt), c2: (65.25pt, 110.00pt), end: (65.25pt, 114.00pt)),)),
    (from: 2, to: 0, head-from: "none", head-to: "none", style: "dashed", path: ((c1: (65.25pt, 40.00pt), c2: (65.25pt, 44.00pt), end: (65.25pt, 48.00pt)),)),
    (from: 3, to: 0, head-from: "none", head-to: "none", style: "dashed", label: [refers to], path: ((c1: (193.00pt, 28.00pt), c2: (193.00pt, 32.00pt), end: (193.00pt, 36.00pt)), (c1: (150.42pt, 36.00pt), c2: (107.83pt, 36.00pt), end: (65.25pt, 36.00pt)), (c1: (65.25pt, 40.00pt), c2: (65.25pt, 44.00pt), end: (65.25pt, 48.00pt)))),
  ),
)
