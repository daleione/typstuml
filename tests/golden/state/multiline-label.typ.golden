#set page(width: auto, height: auto, margin: 8pt)
#set text(size: 10pt)
#import "/blockcell/lib.typ": *

#state-layout(
  nodes: (
    (id: "__initial__", kind: "initial", x: 63.00pt, y: 30.00pt, w: 18.00pt, h: 18.00pt, display: "", body: (), fill: none, border-style: "solid", border-color: none),
    (id: "Connecting", kind: "simple", x: 30.00pt, y: 94.00pt, w: 84.00pt, h: 32.00pt, display: "Connecting", body: (), fill: none, border-style: "solid", border-color: none),
    (id: "Online", kind: "simple", x: 42.40pt, y: 172.00pt, w: 59.20pt, h: 32.00pt, display: "Online", body: (), fill: none, border-style: "solid", border-color: none),
    (id: "__final__", kind: "final", x: 63.00pt, y: 250.00pt, w: 18.00pt, h: 18.00pt, display: "", body: (), fill: none, border-style: "solid", border-color: none),
  ),
  transitions: (
    (from: "__initial__", to: "Connecting", event: none, guard: none, action: none, style: "solid", color: none, self-loop: false, back: false, bow-side: "max"),
    (from: "Connecting", to: "Online", event: "connected\\n", guard: none, action: "start heartbeat", style: "solid", color: none, self-loop: false, back: false, bow-side: "max"),
    (from: "Online", to: "Connecting", event: "timeout\\n", guard: "retries left", action: none, style: "solid", color: none, self-loop: false, back: true, bow-side: "max"),
    (from: "Online", to: "__final__", event: "disconnect", guard: none, action: none, style: "solid", color: none, self-loop: false, back: false, bow-side: "max"),
  ),
  notes: (
  ),
  page: (240.00pt, 298.00pt),
  title: none,
  hide-empty-description: false,
  direction: "tb",
)
